<Window x:Class="TechEquipments.Views.Qr.QrScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        Title="Scan QR"
        Width="780" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FF1E1E1E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="10" BorderBrush="#33FFFFFF" BorderThickness="1">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform" />
                <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                        Margin="10" Padding="8"
                        Background="#66000000" CornerRadius="8">
                    <TextBlock x:Name="StatusText"
                               Foreground="White"
                               FontSize="14"
                               Text="Camera: starting..." />
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <dx:SimpleButton Width="120" Content="Cancel"
                             Style="{DynamicResource AppButtonStyle}"
                             Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
