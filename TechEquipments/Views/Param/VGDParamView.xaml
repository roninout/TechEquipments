<UserControl x:Class="TechEquipments.Views.Param.VGDParamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxc="http://schemas.devexpress.com/winfx/2008/xaml/charts"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxch="clr-namespace:DevExpress.Xpf.Charts;assembly=DevExpress.Xpf.Charts.v21.2"
             xmlns:conv="clr-namespace:TechEquipments"
             MinHeight="260" MinWidth="520">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLength"/>
        <conv:VGDStateToTextConverter x:Key="StateToText"/>
        <conv:DiDoValueToBrushConverter x:Key="DiDoValueToBrush"/>
        <conv:DiDoValueToTextConverter x:Key="DiDoValueToText"/>

        <!-- Man==true => зелёная подложка, иначе прозрачная/серая -->
        <Style x:Key="ManStationBackgroundStyle" TargetType="{x:Type Border}">
            <!--<Setter Property="Background" Value="#40A0A0A0"/>-->
            <!-- серый полупрозрачный -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding Man}" Value="True">
                    <Setter Property="Background" Value="#97DC74"/>
                    <!-- зелёный полупрозрачный -->
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Общий стиль кнопок станции -->
        <Style x:Key="ManStationButtonStyle" TargetType="{x:Type dx:SimpleButton}">
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <!--<Setter Property="BorderThickness" Value="1"/>-->
            <!--<Setter Property="Background" Value="#FFD6D6D6"/>-->
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- State TextEdit style: color + blink -->
        <Style x:Key="StateTextEditStyle" TargetType="{x:Type dxe:TextEdit}" BasedOn="{StaticResource AppBaseEditStyle}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>

            <!-- default background -->
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#FFE6E6E6"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>

                <!-- 0: closed (solid gray) -->
                <DataTrigger Binding="{Binding State}" Value="0">
                    <Setter Property="Background" Value="#FFD6D6D6"/>
                    <Setter Property="BorderBrush" Value="Black"/>
                </DataTrigger>

                <!-- 1: opened (solid green) -->
                <DataTrigger Binding="{Binding State}" Value="1">
                    <Setter Property="Background" Value="#FFB7F2B7"/>
                    <Setter Property="BorderBrush" Value="Black"/>
                </DataTrigger>

                <!-- 2: alarm opening (blink red) -->
                <DataTrigger Binding="{Binding State}" Value="2">
                    <Setter Property="Background" Value="#FFFFD0D0"/>
                    <Setter Property="BorderBrush" Value="#FFB00000"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BlinkAlarmOpen">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="BlinkAlarmOpen"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <!-- 3: alarm closure (blink red) -->
                <DataTrigger Binding="{Binding State}" Value="3">
                    <Setter Property="Background" Value="#FFFFD0D0"/>
                    <Setter Property="BorderBrush" Value="#FFB00000"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BlinkAlarmClose">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="BlinkAlarmClose"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <!-- 4: opening (blink green) -->
                <DataTrigger Binding="{Binding State}" Value="4">
                    <Setter Property="Background" Value="#FFD6FFD6"/>
                    <Setter Property="BorderBrush" Value="#FF007A00"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BlinkOpening">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" From="#FFD6FFD6" To="#FF2ECC71" Duration="0:0:0.45"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="BlinkOpening"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <!-- 5: closing (blink gray) -->
                <DataTrigger Binding="{Binding State}" Value="5">
                    <Setter Property="Background" Value="#FFEDEDED"/>
                    <Setter Property="BorderBrush" Value="#FF606060"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BlinkClosing">
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" From="#FFEDEDED" To="#FFB0B0B0" Duration="0:0:0.45"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <RemoveStoryboard BeginStoryboardName="BlinkClosing"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>

            </Style.Triggers>
        </Style>

    </UserControl.Resources>


    <dxlc:LayoutControl Margin="0">
        <dxlc:LayoutGroup Header="tryrtyr" View="Group" GroupBoxDisplayMode="Light">

            <!-- ================= LEFT BLOCK ================= -->
            <dxlc:LayoutGroup View="GroupBox" GroupBoxDisplayMode="Light" Width="220" HorizontalAlignment="Left">

                <dxlc:LayoutGroup Orientation="Vertical">

                    <!-- State -->
                    <dxlc:LayoutGroup Header="LayoutGroup" View="Group">
                        <dxe:TextEdit Tag="State"
                                      Width="158"
                                      HorizontalAlignment="Center"
                                      HorizontalContentAlignment="Center"
                                      EditValue="{Binding State, Converter={StaticResource StateToText}, Mode=OneWay}"
                                      Style="{StaticResource StateTextEditStyle}"/>
                    </dxlc:LayoutGroup>


                    <Grid Margin="20,0,20,0">

                        <!-- ====== Manual station (Open/Close) ====== -->
                            <Border Height="315" Style="{StaticResource ManStationBackgroundStyle}" Padding="8" BorderBrush="Gray" BorderThickness="1" CornerRadius="0">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ================= OPEN (Man=1) ================= -->
                                <Grid Grid.Row="0">
                                    <!-- сама кнопка -->
                                    <dx:SimpleButton Content="Open" Click="Man_Open_Click">
                                        <dx:SimpleButton.Style>
                                            <Style TargetType="{x:Type dx:SimpleButton}" BasedOn="{StaticResource ManStationButtonStyle}">
                                                <Style.Triggers>
                                                    <!-- Активная рамка, когда Man=true -->
                                                    <DataTrigger Binding="{Binding Man}" Value="True">
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <!-- Mode=true => Auto: блокируем -->
                                                    <DataTrigger Binding="{Binding Mode}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </dx:SimpleButton.Style>
                                    </dx:SimpleButton>

                                    <!-- серый overlay: показываем, когда OPEN не активна (Man=false) или Mode=true -->
                                    <Rectangle IsHitTestVisible="False" Fill="#80BEBEBE" Stroke="#FF8A8A8A" StrokeThickness="1" Margin="8">
                                        <Rectangle.Style>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- Open не активна -->
                                                    <DataTrigger Binding="{Binding Man}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Grid>

                                <!-- ================= CLOSE (Man=0) ================= -->
                                <Grid Grid.Row="1">
                                    <!-- сама кнопка -->
                                    <dx:SimpleButton Content="Close" Click="Man_Close_Click">
                                        <dx:SimpleButton.Style>
                                            <Style TargetType="{x:Type dx:SimpleButton}" BasedOn="{StaticResource ManStationButtonStyle}">
                                                <Style.Triggers>
                                                    <!-- Активная рамка, когда Man=false -->
                                                    <DataTrigger Binding="{Binding Man}" Value="False">
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <!-- Mode=true => Auto: блокируем -->
                                                    <DataTrigger Binding="{Binding Mode}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </dx:SimpleButton.Style>
                                    </dx:SimpleButton>

                                    <!-- серый overlay: показываем, когда CLOSE не активна (Man=true) или Mode=true -->
                                    <Rectangle IsHitTestVisible="False" Fill="#80BEBEBE" Stroke="#FF8A8A8A" StrokeThickness="1" Margin="8">
                                        <Rectangle.Style>
                                            <Style TargetType="{x:Type Rectangle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- Close не активна -->
                                                    <DataTrigger Binding="{Binding Man}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Grid>

                            </Grid>
                        </Border>
                            
                    </Grid>

                    <!-- Unit + Mode (Man/Auto) -->
                    <dxlc:LayoutGroup Header="LayoutGroup" View="Group" VerticalAlignment="Bottom">
                        <StackPanel HorizontalAlignment="Center">

                            <TextBlock Text="{Binding Unit}" HorizontalAlignment="Center" Style="{StaticResource AppTextBlockStyle}"/>

                            <!-- Mode: false = Man, true = Auto -->
                            <ToggleButton Tag="Mode"
                                          Width="158" Height="40" Margin="0,8,0,0" FontWeight="Bold"
                                          HorizontalAlignment="Center"
                                          IsChecked="{Binding Mode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="ParamEditable_ToggleChanged"
                                          Unchecked="ParamEditable_ToggleChanged">

                                <ToggleButton.Style>
                                    <Style TargetType="{x:Type ToggleButton}">
                                        <Setter Property="Content" Value="Manual"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Content" Value="Auto"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>

                            </ToggleButton>

                        </StackPanel>
                    </dxlc:LayoutGroup>

                </dxlc:LayoutGroup>

            </dxlc:LayoutGroup>

            <!-- ================= CENTER BLOCK ================= -->
            <dxlc:LayoutGroup Orientation="Vertical" HorizontalAlignment="Stretch">

                <!-- ====== CHART (по умолчанию виден) ====== -->
                <dxlc:LayoutItem HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 Visibility="{Binding DataContext.Trend.IsChartVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">

                    <!-- Trend chart (DevExpress WPF Charts).
                         IMPORTANT:
                         - VisualRange (AxisXMin/AxisXMax) = текущая видимая область.
                         - WholeRange  (AxisXWholeMin/AxisXWholeMax) = весь диапазон загруженных данных.
                           WholeRange должен быть шире VisualRange, чтобы работали scrollbars/пан.
                    -->
                    <dxc:ChartControl DataSource="{Binding DataContext.Trend.Points, RelativeSource={RelativeSource AncestorType=Window}}"
                                      BoundDataChanged="ParamChart_BoundDataChanged"
                                      CustomDrawCrosshair="Chart_CustomDrawCrosshair">
                        <dxc:ChartControl.Diagram>
                            <dxc:XYDiagram2D
                                SeriesDataMember="Series"
                                EnableAxisXNavigation="True"
                                EnableAxisYNavigation="False"
                                Scroll="ParamChart_DiagramScroll"
                                Zoom="ParamChart_DiagramZoom">

                                <dxc:XYDiagram2D.NavigationOptions>
                                    <dxc:NavigationOptions UseMouse="True" UseScrollBars="True" UseKeyboard="True"/>
                                </dxc:XYDiagram2D.NavigationOptions>

                                <!-- AxisX -->
                                <dxc:XYDiagram2D.AxisX>
                                    <dxc:AxisX2D>

                                        <dxc:AxisX2D.VisualRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                MinValue="{Binding DataContext.Trend.AxisXMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                MaxValue="{Binding DataContext.Trend.AxisXMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisX2D.VisualRange>

                                        <dxc:AxisX2D.WholeRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                MinValue="{Binding DataContext.Trend.AxisXWholeMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                MaxValue="{Binding DataContext.Trend.AxisXWholeMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisX2D.WholeRange>

                                        <dxc:AxisX2D.DateTimeScaleOptions>
                                            <dxc:ContinuousDateTimeScaleOptions GridAlignment="Second" AutoGrid="True"/>
                                        </dxc:AxisX2D.DateTimeScaleOptions>

                                    </dxc:AxisX2D>
                                </dxc:XYDiagram2D.AxisX>

                                <!-- AxisY: -->
                                <dxc:XYDiagram2D.AxisY>
                                    <dxc:AxisY2D>
                                        <dxc:AxisY2D.VisualRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                       MinValue="{Binding DataContext.Trend.AxisYMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       MaxValue="{Binding DataContext.Trend.AxisYMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisY2D.VisualRange>
                                        <dxc:AxisY2D.WholeRange>
                                            <dxc:Range AutoSideMargins="False" SideMarginsValue="0"
                                                       MinValue="{Binding DataContext.Trend.AxisYMin, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       MaxValue="{Binding DataContext.Trend.AxisYMax, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </dxc:AxisY2D.WholeRange>
                                    </dxc:AxisY2D>
                                </dxc:XYDiagram2D.AxisY>

                                <!-- ====== Series ====== -->
                                <dxc:XYDiagram2D.SeriesTemplate>
                                    <dxc:AreaStepSeries2D
                                        ArgumentDataMember="Time"
                                        ValueDataMember="Value"
                                        ArgumentScaleType="DateTime"
                                        MarkerVisible="False">
                                    </dxc:AreaStepSeries2D>
                                </dxc:XYDiagram2D.SeriesTemplate>

                            </dxc:XYDiagram2D>
                        </dxc:ChartControl.Diagram>
                    </dxc:ChartControl>

                </dxlc:LayoutItem>

                <!-- ====== SETTINGS (PLC / DI-DO / Alarm) ====== -->
                <dxlc:LayoutItem Visibility="{Binding DataContext.Trend.IsSettingsVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">

                    <!-- вложенный LayoutControl, чтобы можно было показывать/скрывать целиком -->
                    <dxlc:LayoutControl Margin="-12">

                        <dxlc:LayoutGroup Orientation="Vertical" View="Group" GroupBoxDisplayMode="Light">

                            <!-- ====== PLC settings ====== -->
                            <dxlc:LayoutGroup x:Name="PlcSettingsGroup" Header="PLC settings" View="GroupBox" HorizontalAlignment="Stretch" Orientation="Vertical" Visibility="Collapsed">

                            </dxlc:LayoutGroup>

                            <!-- ====== DI settings ====== -->
                            <dxlc:LayoutGroup x:Name="DiSettingsGroup" Header="DI chanels" View="GroupBox" HorizontalAlignment="Stretch" Orientation="Vertical" Visibility="Collapsed">

                                <dxlc:LayoutItem>
                                    <ScrollViewer Height="215" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding DataContext.ParamDiRows, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="55"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- "{Equipment}: {Description}" -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Title}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource AppTextBlockStyle}"/>

                                                        <!-- прямоугольник Value -->
                                                        <Border Grid.Column="1"
                                                                Width="54"
                                                                Height="24"
                                                                Margin="0,2,0,0"
                                                                BorderBrush="Black"
                                                                BorderThickness="1"
                                                                Background="{Binding Value, Converter={StaticResource DiDoValueToBrush}}"
                                                                VerticalAlignment="Center"
                                                                Cursor="Hand"
                                                                ToolTip="Go to this equipment"
                                                                MouseLeftButtonUp="DiDoValue_MouseLeftButtonUp">
                                                            <TextBlock Text="{Binding Value, Converter={StaticResource DiDoValueToText}}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontWeight="SemiBold"/>
                                                        </Border>

                                                        <!-- chanel -->
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding ChanelShort}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   Style="{StaticResource AppTextBlockStyle}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </dxlc:LayoutItem>
                            </dxlc:LayoutGroup>

                            <!-- ====== DO settings ====== -->
                            <dxlc:LayoutGroup x:Name="DoSettingsGroup" Header="DO chanels" View="GroupBox" HorizontalAlignment="Stretch" Orientation="Vertical" Visibility="Collapsed">

                                <dxlc:LayoutItem>
                                    <ScrollViewer Height="215" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding DataContext.ParamDoRows, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="55"/>
                                                            <ColumnDefinition Width="55"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- "{Equipment}: {Description}" -->
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Title}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Style="{StaticResource AppTextBlockStyle}"/>

                                                        <!-- прямоугольник Value -->
                                                        <Border Grid.Column="1"
                                                                Width="54"
                                                                Height="25"
                                                                Margin="0,2,0,0"
                                                                BorderBrush="Black"
                                                                BorderThickness="1"
                                                                Background="{Binding Value, Converter={StaticResource DiDoValueToBrush}}"
                                                                VerticalAlignment="Center"
                                                                Cursor="Hand"
                                                                ToolTip="Go to this equipment"
                                                                MouseLeftButtonUp="DiDoValue_MouseLeftButtonUp">
                                                            <TextBlock Text="{Binding Value, Converter={StaticResource DiDoValueToText}}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>

                                                        <!-- chanel -->
                                                        <TextBlock Grid.Column="2"
                                                                    Text="{Binding ChanelShort}"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right"
                                                                    Style="{StaticResource AppTextBlockStyle}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </dxlc:LayoutItem>
                            </dxlc:LayoutGroup>

                            <!-- ====== Alarm settings ====== -->
                            <dxlc:LayoutGroup x:Name="AlarmSettingsGroup" Header="Alarm settings" View="GroupBox" HorizontalAlignment="Stretch" Orientation="Vertical" Visibility="Collapsed">

                                <!--Alarm message signaling status-->
                                <dxlc:LayoutItem Label="Alarm message signaling status" Margin="0,0,0,50">
                                    <dxe:ToggleSwitchEdit Tag="AlarmEn" 
                                                          Width="80" HorizontalAlignment="Right"
                                                          UncheckedStateContent="Off"
                                                          CheckedStateContent="On"
                                                          IsChecked="{Binding AlarmEn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          EditValueChanged="ParamEditable_EditValueChanged"
                                                          Style="{StaticResource AppBaseEditStyle}" />
                                </dxlc:LayoutItem>

                                <!--Control time of valve opening-->
                                <dxlc:LayoutItem Label="Control time of valve opening">
                                    <dxe:TextEdit Tag="TOpen"
                                                  Width="80" HorizontalAlignment="Right"
                                                  EditValue="{Binding TOpen, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppBaseEditStyle}"
                                                  PreviewKeyDown="ParamEditable_EditValueChanged"/>
                                </dxlc:LayoutItem>

                                <!--Control time of valve closing-->
                                <dxlc:LayoutItem Label="Control time of valve closing">
                                    <dxe:TextEdit Tag="TClose"
                                                  Width="80" HorizontalAlignment="Right"
                                                  EditValue="{Binding TClose, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppBaseEditStyle}"
                                                  PreviewKeyDown="ParamEditable_EditValueChanged"/>
                                </dxlc:LayoutItem>

                            </dxlc:LayoutGroup>

                        </dxlc:LayoutGroup>

                    </dxlc:LayoutControl>

                </dxlc:LayoutItem>

            </dxlc:LayoutGroup>

            <!-- ================= RIGHT BLOCK (buttons) ================= -->
            <dxlc:LayoutGroup View="Group" GroupBoxDisplayMode="Light"
                  Header=""
                  HorizontalAlignment="Right"
                  VerticalAlignment="Stretch">

                <!-- Один LayoutItem, внутри Grid с "пружиной" -->
                <dxlc:LayoutItem VerticalAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- верхние кнопки -->
                            <RowDefinition Height="*"/>
                            <!-- пружина -->
                            <RowDefinition Height="Auto"/>
                            <!-- нижняя кнопка -->
                        </Grid.RowDefinitions>

                        <!-- Верх: Chart + Params -->
                        <StackPanel Grid.Row="0" Orientation="Vertical" VerticalAlignment="Top">

                            <!-- Chart -->
                            <dx:SimpleButton x:Name="ChartButton"
                                 Width="60" Height="60"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="ShowChartButton_Click"
                                 ToolTip="Chart"
                                 Glyph="{dx:DXImage 'SvgImages/Chart/Chart.svg'}"
                                 Style="{StaticResource AppButtonStyle}" />

                            <!-- PLC settings -->
                            <dx:SimpleButton x:Name="PLCButton"
                                 Width="60" Height="60"
                                 Margin="0,8,0,0"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="PLCButton_Click"
                                 ToolTip="PLC settings"
                                 Glyph="{dx:DXImage 'SvgImages/Scheduling/ViewSettings.svg'}"
                                 Style="{StaticResource AppButtonStyle}" />

                            <!-- DI/DO settings -->
                            <dx:SimpleButton x:Name="DI_DOButton"
                                 Width="60" Height="60"
                                 Margin="0,8,0,0"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="DI_DOButton_Click"
                                 ToolTip="DI/DO settings"
                                 Glyph="{dx:DXImage 'SvgImages/DiagramIcons/ChangeConnectorType.svg'}"
                                 Style="{StaticResource AppButtonStyle}" />

                            <!-- Alarm settings -->
                            <dx:SimpleButton x:Name="AlarmSettingsButton"
                                 Width="60" Height="60"
                                 Margin="0,8,0,0"
                                 Padding="0" GlyphWidth="40" GlyphHeight="40"
                                 Click="AlarmSettingsButton_Click"
                                 ToolTip="Alarm settings"
                                 Glyph="{dx:DXImage 'SvgImages/XAF/State_Validation_Warning.svg'}"
                                 Style="{StaticResource AppButtonStyle}" />

                        </StackPanel>

                        <!-- Низ: Live/History (прилипает к низу автоматически) -->
                        <dx:SimpleButton Grid.Row="2"
                             x:Name="TrendModeButton"
                             Width="60" Height="60"
                             Padding="0" GlyphWidth="40" GlyphHeight="40"
                             Click="LiveButton_Click"
                             Visibility="{Binding DataContext.Trend.IsChartVisible, RelativeSource={RelativeSource AncestorType=Window},Converter={StaticResource BoolToVis}}">

                            <dx:SimpleButton.Style>
                                <Style TargetType="{x:Type dx:SimpleButton}" BasedOn="{StaticResource AppButtonStyle}">
                                    <!-- По умолчанию Live -->
                                    <Setter Property="Glyph" Value="{dx:DXImage SvgImages/XAF/Action_Debug_Start.svg}"/>
                                    <Setter Property="ToolTip" Value="Live"/>

                                    <Style.Triggers>
                                        <!-- Если History -->
                                        <DataTrigger Binding="{Binding DataContext.Trend.IsLiveMode, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                            <Setter Property="Glyph" Value="{dx:DXImage SvgImages/Arrows/Last.svg}"/>
                                            <Setter Property="ToolTip" Value="History"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </dx:SimpleButton.Style>

                        </dx:SimpleButton>

                    </Grid>
                </dxlc:LayoutItem>

