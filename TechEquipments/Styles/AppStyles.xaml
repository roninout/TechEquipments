<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol">

    <!-- ============ BASE TEXT ============ -->
    <Style x:Key="AppTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

    <!-- ============ EDITORS (TextEdit / ComboBoxEdit etc) ============ -->
    <Style x:Key="AppBaseEditStyle" TargetType="{x:Type dxe:BaseEdit}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="10,0"/>
    </Style>

    <!-- ============ BUTTONS ============ -->
    <Style x:Key="AppButtonStyle" TargetType="{x:Type dx:SimpleButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="16,0"/>
    </Style>

    <!-- ToggleButton (стрелка слева / др. тумблеры) -->
    <Style x:Key="AppToggleStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,0"/>
    </Style>

    <!-- ============ LISTBOX ============ -->
    <Style x:Key="AppListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============ GRID HEADERS ============ -->
    <Style x:Key="AppGridColumnHeaderStyle" TargetType="{x:Type dxg:GridColumnHeader}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ============ TABLE VIEW ============ -->
    <Style x:Key="AppTableViewStyle" TargetType="{x:Type dxg:TableView}">
        <Setter Property="AllowEditing" Value="False"/>
        <Setter Property="RowMinHeight" Value="36"/>
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AppGridColumnHeaderStyle}"/>
        <Setter Property="ShowGroupPanel" Value="False"/>
        <Setter Property="AllowPerPixelScrolling" Value="True"/>
    </Style>

    <!-- ============ TABS ============ -->
    <Style x:Key="AppTabControlStyle" TargetType="{x:Type dx:DXTabControl}">
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="AppTabItemStyle" TargetType="{x:Type dx:DXTabItem}">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ============ Label / Caption text ============ -->
    <Style x:Key="AppLabelTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ============ обычный текст ============ -->
    <Style x:Key="AppTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Opacity" Value="0.9"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Общий шаблон лейбла Enabled/Disabled + жирность -->
    <DataTemplate x:Key="EnabledDisabledLabelTemplate">
        <TextBlock>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Disabled"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Path=Content.IsChecked, RelativeSource={RelativeSource AncestorType={x:Type dxlc:LayoutItem}}}" Value="True">
                            <Setter Property="Text" Value="Enabled"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </DataTemplate>

    <!-- Стиль для LayoutItem с CheckEdit внутри -->
    <Style x:Key="BoolCheckLayoutItemStyle" TargetType="{x:Type dxlc:LayoutItem}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>

        <!-- чтобы зона лейбла гарантированно была -->
        <Setter Property="Label" Value=" "/>

        <Setter Property="LabelTemplate" Value="{StaticResource EnabledDisabledLabelTemplate}"/>
    </Style>

    <!-- (опционально) стиль для чекбокса -->
    <Style x:Key="BoolParamCheckEditStyle" TargetType="{x:Type dxe:CheckEdit}">
        <Setter Property="Width" Value="20"/>
        <Setter Property="IsReadOnly" Value="False"/>
    </Style>
    
    <!--FOR TREND-->
    <Style x:Key="HideWhenChartVisible_Group" TargetType="{x:Type dxlc:LayoutGroup}">
        <Setter Property="Visibility" Value="Visible"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShowWhenChartVisible_Item" TargetType="{x:Type dxlc:LayoutItem}">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ChartsToggleButtonStyle" TargetType="{x:Type dx:SimpleButton}" BasedOn="{StaticResource AppButtonStyle}">
        <Setter Property="Content" Value="Графики"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsParamChartVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                <Setter Property="Content" Value="Параметры"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий текст для Forced -->
    <Style x:Key="ForcedBlinkTextStyle" TargetType="{x:Type TextBlock}">
        <!-- Внешний вид -->
        <Setter Property="Foreground" Value="DarkOrange"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1"/>

        <Style.Triggers>
            <!-- Когда ForceCmd=true -> запускаем мигание -->
            <DataTrigger Binding="{Binding ForceCmd}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="ForcedBlinkBegin">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Мигание: Opacity 1 <-> 0.15 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.15"
                                             Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <!-- Когда ForceCmd станет false -> стопаем мигание и возвращаем Opacity -->
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="ForcedBlinkBegin"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Мигающий текст для AlarmHealth -->
    <Style x:Key="AlarmHealthBlinkTextStyle" TargetType="{x:Type TextBlock}">
        <!-- Внешний вид -->
        <Setter Property="Foreground" Value="Red"/>
        <!--<Setter Property="Foreground" Value="CornflowerBlue"/>-->
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="1"/>

        <Style.Triggers>
            <!-- Когда AlarmHealth=true -> запускаем мигание -->
            <DataTrigger Binding="{Binding AlarmHealth}" Value="True">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="AlarmHealthBlinkBegin">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- Мигание: Opacity 1 <-> 0.15 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.15"
                                             Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <!-- Когда AlarmHealth станет false -> стопаем мигание и возвращаем Opacity -->
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="AlarmHealthBlinkBegin"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- VGD: State TextEdit style (color + blink) -->
    <Style x:Key="StateTextEditStyle"
       TargetType="{x:Type dxe:TextEdit}"
       BasedOn="{StaticResource AppBaseEditStyle}">

        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="Black"/>

        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#FFE6E6E6"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <DataTrigger Binding="{Binding State}" Value="0">
                <Setter Property="Background" Value="#FFD6D6D6"/>
                <Setter Property="BorderBrush" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="1">
                <Setter Property="Background" Value="#FFB7F2B7"/>
                <Setter Property="BorderBrush" Value="Black"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="2">
                <Setter Property="Background" Value="#FFFFD0D0"/>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkAlarmOpen">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkAlarmOpen"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="3">
                <Setter Property="Background" Value="#FFFFD0D0"/>
                <Setter Property="BorderBrush" Value="#FFB00000"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkAlarmClose">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFFFD0D0" To="#FFFF4D4D" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkAlarmClose"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="4">
                <Setter Property="Background" Value="#FFD6FFD6"/>
                <Setter Property="BorderBrush" Value="#FF007A00"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkOpening">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFD6FFD6" To="#FF2ECC71" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkOpening"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding State}" Value="5">
                <Setter Property="Background" Value="#FFEDEDED"/>
                <Setter Property="BorderBrush" Value="#FF606060"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="BlinkClosing">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetProperty="Background.Color"
                                        From="#FFEDEDED" To="#FFB0B0B0" Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="BlinkClosing"/>
                </DataTrigger.ExitActions>
            </DataTrigger>

        </Style.Triggers>
    </Style>

    <!-- Man==true => зелёная подложка, иначе прозрачная/серая -->
    <Style x:Key="ManStationBackgroundStyle" TargetType="{x:Type Border}">
        <!--<Setter Property="Background" Value="#40A0A0A0"/>-->
        <!-- серый полупрозрачный -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding Man}" Value="True">
                <Setter Property="Background" Value="#97DC74"/>
                <!-- зелёный полупрозрачный -->
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Общий стиль кнопок Man/Auto -->
    <Style x:Key="ManStationButtonStyle" TargetType="{x:Type dx:SimpleButton}">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="BorderBrush" Value="Black"/>
        <!--<Setter Property="BorderThickness" Value="1"/>-->
        <!--<Setter Property="Background" Value="#FFD6D6D6"/>-->
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Forced label: по умолчанию скрыт, при ValueForced=True показывает и мигает -->
    <Style x:Key="DIDOForcedBlinkTextStyle"
       TargetType="{x:Type TextBlock}"
       BasedOn="{StaticResource AppTextBlockStyle}">
        <Setter Property="Text" Value="Forced"/>
        <Setter Property="Foreground" Value="Orange"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Visibility" Value="Collapsed"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding ValueForced}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>

                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="ForcedBlinkStoryboard">
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <!-- мигание: 1.0 -> 0.25 -> 1.0 -->
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.25"
                                         Duration="0:0:0.45"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <RemoveStoryboard BeginStoryboardName="ForcedBlinkStoryboard"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
